SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/oroye_campaign
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_local_database_password

SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=465
SPRING_MAIL_USERNAME=your-email@example.com
SPRING_MAIL_PASSWORD=your-mail-password
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_STARTTLS_ENABLE=true
SPRING_MAIL_SSL_ENABLE=true

APP_EMAIL=your-email@example.com
APP_ALLOWED_ORIGINS=http://localhost:3000
APP_UPLOAD_DIR=uploads

CALLBACK_URL=http://localhost:3000/payment-success
PAYSTACK_SECRET_KEY=your-paystack-secret
JWT_SECRET=replace-this-with-a-long-random-secret
JWT_EXPIRATION=86400000